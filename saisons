use strict;
use warnings;
use utf8;
use open qw(:utf8);
binmode STDOUT, ':utf8';
binmode STDERR, ':utf8';
use lib "$ENV{HOME}/.local/lib";
use lib 'lib';
use Module::Pluggable (
    search_path => 'App::Saisons::Adapter',
    require     => 1,
    inner       => 0,
);
use App::Saisons;
use App::Saisons::UI;

if (@ARGV && $ARGV[0] eq '--version') {
    print "saisons $App::Saisons::VERSION\n";
    exit 0;
}

# ── load sessions from all adapters ──────────────────────────────────────────
# To add a new agent: see lib/Saisons/Adapter/HOWTO.md

my @adapters = map { $_->new }
               grep { $_->can('find_sessions') }
               plugins();

my @sessions;
my %running;

for my $adapter (@adapters) {
    push @sessions, $adapter->find_sessions;
    %running = (%running, $adapter->running);
}

@sessions = sort { $b->{date} cmp $a->{date} } @sessions;
die "No sessions found.\n" unless @sessions;

# ── detect launcher ───────────────────────────────────────────────────────────

my $launcher = $ENV{CLAUDE_SESSIONS_LAUNCHER} // do {
    if    ($ENV{TMUX})                                          { 'tmux' }
    elsif ($ENV{STY})                                           { 'screen' }
    elsif (($ENV{DISPLAY} || $ENV{WAYLAND_DISPLAY})
           && `which gnome-terminal 2>/dev/null` =~ /\S/)      { 'gnome-terminal' }
    elsif (($ENV{TERM_PROGRAM} // '') eq 'iTerm.app')          { 'iterm' }
    elsif ($^O eq 'darwin')                                     { 'terminal-app' }
    else                                                        { 'inline' }
};

# ── UI loop — keep running until user quits ───────────────────────────────────

my $ui = App::Saisons::UI->new;

while (1) {
    # Refresh running sessions each iteration
    %running = ();
    for my $adapter (@adapters) {
        %running = (%running, $adapter->running);
    }

    my @selected = $ui->interactive_select(\@sessions, \%running);

    # Empty selection means the user pressed q/ESC — exit
    last unless @selected;

    # Launch selected sessions then loop back to the list
    my %by_adapter;
    for my $s (@selected) {
        push @{ $by_adapter{ ref $s->{_adapter} } }, $s;
    }
    for my $group (values %by_adapter) {
        $group->[0]{_adapter}->launch($group, $launcher);
    }
}
